# OnBoard Health — ortam değişkenleri
# MVP Play Store build öncesi ZORUNLU alanları doldurun

# ========== ZORUNLU (Play Store) ==========
EXPO_PUBLIC_SUPPORT_EMAIL=destek@sirketiniz.com
EXPO_PUBLIC_PRIVACY_POLICY_URL=https://sirketiniz.com/gizlilik

# ========== OPSİYONEL (MVP v1.0 — boş bırakın) ==========
# Bulut paneli MVP'de kapalı; sonraki sürümde kullanılır
EXPO_PUBLIC_SUPABASE_URL=
EXPO_PUBLIC_SUPABASE_ANON_KEY=
EXPO_PUBLIC_DEFAULT_STUDIO_ID=

# Build sonrası Metro için: npx expo start -c
