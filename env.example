# Bu dosyayı kopyalayıp proje kökünde `.env` olarak kaydedin (adı tam olarak .env)
# Değerleri Supabase Dashboard > Project Settings > API bölümünden alın
# Expo: EXPO_PUBLIC_ ile başlamalı; değişiklikten sonra Metro'yu yeniden başlatın (npx expo start -c)

EXPO_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
# (İsteğe bağlı) public.studios tablosundaki bir satırın id (UUID) — Özet > Bulut kartı için
EXPO_PUBLIC_DEFAULT_STUDIO_ID=
